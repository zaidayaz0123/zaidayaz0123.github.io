<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reliance Industries — Interactive Sensitivity Model</title>
<style>
  :root{
    --ink:#0d0d0d;
    --ink2:#3a3d44;
    --accent:#7a1f2b;
    --accent-tint:#f3e9ea;
    --grey:#6b6e74;
    --line:#d7d7d5;
    --panel:#f7f7f5;
    --green:#1e6b3c;
    --green-tint:#e8f1ec;
    --amber:#8a6d1d;
    --amber-tint:#f5f0e0;
    --red:#9c2b2b;
    --red-tint:#f7eaea;
    --paper:#ffffff;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--paper);
    color:var(--ink);
    font-family:Helvetica,Arial,sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  .wrap{max-width:920px;margin:0 auto;padding:28px 24px 60px;}

  header{border-bottom:2px solid var(--ink);padding-bottom:14px;margin-bottom:6px;position:relative;}
  header::after{content:"";display:block;height:1px;background:var(--line);margin-top:5px;}
  .eyebrow-row{display:flex;justify-content:space-between;font-size:11px;font-weight:700;letter-spacing:.06em;color:var(--grey);text-transform:uppercase;margin-bottom:10px;}
  h1{
    font-family:Georgia,"Times New Roman",serif;
    font-weight:700;
    font-size:clamp(26px,4.4vw,38px);
    line-height:1.08;
    margin:0 0 6px;
  }
  .subtitle{font-size:13.5px;color:var(--ink2);margin:0;}
  .tags{font-size:12px;color:var(--grey);margin-top:6px;}

  .layout{display:grid;grid-template-columns:1.35fr 1fr;gap:36px;margin-top:30px;align-items:start;}
  @media (max-width:760px){.layout{grid-template-columns:1fr;}}

  .controls-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;}
  .controls-head h2{font-size:13px;text-transform:uppercase;letter-spacing:.05em;margin:0;}
  #resetBtn{
    background:none;border:1px solid var(--line);color:var(--ink2);
    font-size:11.5px;padding:5px 10px;border-radius:3px;cursor:pointer;
    font-family:inherit;
  }
  #resetBtn:hover{border-color:var(--ink);color:var(--ink);}
  #resetBtn:focus-visible, .driver input[type=range]:focus-visible, .toggle input:focus-visible{
    outline:2px solid var(--accent);outline-offset:2px;
  }

  .driver{border-top:1px solid var(--line);padding:16px 0;}
  .driver:last-child{border-bottom:1px solid var(--line);}
  .driver-top{display:flex;justify-content:space-between;align-items:baseline;gap:10px;margin-bottom:2px;}
  .driver-name{font-size:13.5px;font-weight:700;}
  .driver-name .num{color:var(--accent);font-family:Georgia,serif;margin-right:6px;}
  .driver-val{font-size:13.5px;font-weight:700;font-variant-numeric:tabular-nums;white-space:nowrap;}
  .driver-desc{font-size:11.5px;color:var(--grey);margin-bottom:9px;line-height:1.4;}

  input[type=range]{
    -webkit-appearance:none;appearance:none;width:100%;height:22px;background:transparent;cursor:pointer;margin:0;
  }
  input[type=range]::-webkit-slider-runnable-track{height:3px;background:var(--line);border-radius:2px;}
  input[type=range]::-moz-range-track{height:3px;background:var(--line);border-radius:2px;}
  input[type=range]::-webkit-slider-thumb{
    -webkit-appearance:none;height:16px;width:16px;border-radius:50%;
    background:var(--paper);border:2.5px solid var(--accent);margin-top:-6.5px;
    transition:transform .1s;
  }
  input[type=range]:active::-webkit-slider-thumb{transform:scale(1.15);}
  input[type=range]::-moz-range-thumb{
    height:16px;width:16px;border-radius:50%;background:var(--paper);border:2.5px solid var(--accent);
  }
  input[type=range]:disabled{opacity:.35;cursor:not-allowed;}

  .scale-labels{display:flex;justify-content:space-between;font-size:10px;color:var(--grey);margin-top:2px;}

  .toggle{display:flex;align-items:center;gap:7px;font-size:11.5px;color:var(--ink2);margin-top:10px;}
  .toggle input{margin:0;}

  .panel{background:var(--panel);border:1px solid var(--line);padding:22px 22px 20px;position:sticky;top:20px;}
  .panel-label{font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--grey);font-weight:700;margin-bottom:4px;}
  .price{
    font-family:Georgia,"Times New Roman",serif;font-weight:700;
    font-size:44px;line-height:1;margin:2px 0 4px;
    transition:color .15s;
  }
  .upside{font-size:14px;font-weight:700;margin-bottom:14px;}
  .badge{
    display:inline-block;font-size:12px;font-weight:700;letter-spacing:.04em;
    padding:5px 12px;border-radius:2px;margin-bottom:18px;transition:background .15s,color .15s;
  }

  .rangebar{margin:6px 0 18px;}
  .rangebar-track{position:relative;height:6px;background:var(--line);border-radius:3px;margin:22px 4px 6px;}
  .rangebar-fill{position:absolute;left:0;top:0;height:100%;background:var(--ink);border-radius:3px;transition:width .15s;}
  .rangebar-marker{
    position:absolute;top:50%;width:2px;height:16px;background:var(--grey);
    transform:translate(-50%,-50%);
  }
  .rangebar-marker .lbl{
    position:absolute;top:-20px;left:50%;transform:translateX(-50%);
    font-size:9.5px;color:var(--grey);white-space:nowrap;
  }
  .rangebar-dot{
    position:absolute;top:50%;width:13px;height:13px;border-radius:50%;
    background:var(--accent);border:2px solid var(--paper);box-shadow:0 0 0 1px var(--accent);
    transform:translate(-50%,-50%);transition:left .15s;
  }
  .rangebar-labels{display:flex;justify-content:space-between;font-size:10px;color:var(--grey);}

  .divider{height:1px;background:var(--line);margin:16px 0;}
  .crosscheck{font-size:12px;color:var(--ink2);}
  .crosscheck b{color:var(--ink);}

  footer{margin-top:34px;padding-top:14px;border-top:1px solid var(--line);font-size:10.5px;color:var(--grey);line-height:1.6;}
  footer a{color:var(--accent);}
  .methodology{font-size:11px;color:var(--grey);margin-top:16px;line-height:1.5;}

  @media (prefers-reduced-motion:reduce){
    *{transition:none !important;}
  }
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div class="eyebrow-row">
      <span>Zaid Terminal Research Desk</span>
      <span>Interactive Companion &mdash; Section 12 of the Full Report</span>
    </div>
    <h1>Reliance Industries — Sensitivity Model</h1>
    <p class="subtitle">Move any input to see the effect on target price and rating, live.</p>
    <p class="tags">NSE: RELIANCE &nbsp;|&nbsp; BSE: 500325 &nbsp;|&nbsp; CMP Rs 1,327 (17-Jul-2026)</p>
  </header>

  <div class="layout">

    <div class="controls">
      <div class="controls-head">
        <h2>Five key drivers</h2>
        <button id="resetBtn" type="button">Reset to base case</button>
      </div>

      <div class="driver">
        <div class="driver-top">
          <span class="driver-name"><span class="num">01</span>O2C refining &amp; petrochemical margin</span>
          <span class="driver-val" id="v-o2c">US$ 13.0/bbl</span>
        </div>
        <div class="driver-desc">Blended crack-spread proxy behind the Oil-to-Chemicals segment. Current print sits near the top of this range.</div>
        <input type="range" id="s-o2c" min="8" max="19" step="0.1" value="13">
        <div class="scale-labels"><span>Bear $8</span><span>Bull $19</span></div>
      </div>

      <div class="driver">
        <div class="driver-top">
          <span class="driver-name"><span class="num">02</span>Jio Platforms IPO valuation</span>
          <span class="driver-val" id="v-jio">US$ 140 bn</span>
        </div>
        <div class="driver-desc">Disclosed DRHP range is US$100&ndash;180bn. The largest single swing factor in the whole model.</div>
        <input type="range" id="s-jio" min="100" max="180" step="1" value="140">
        <div class="scale-labels"><span>Bear $100bn</span><span>Bull $180bn</span></div>
        <label class="toggle">
          <input type="checkbox" id="t-tail">
          Apply IPO downside-tail scenario (delay / sub-$100bn print) — overrides slider
        </label>
      </div>

      <div class="driver">
        <div class="driver-top">
          <span class="driver-name"><span class="num">03</span>Reliance Retail EBITDA margin</span>
          <span class="driver-val" id="v-retail">7.9%</span>
        </div>
        <div class="driver-desc">Q1 FY27 print was 7.9%, down 80bps YoY on hyperlocal-delivery investment.</div>
        <input type="range" id="s-retail" min="6.5" max="10.5" step="0.1" value="7.9">
        <div class="scale-labels"><span>Bear 6.5%</span><span>Bull 10.5%</span></div>
      </div>

      <div class="driver">
        <div class="driver-top">
          <span class="driver-name"><span class="num">04</span>New Energy segment value</span>
          <span class="driver-val" id="v-ne">Rs 1,17,375 cr</span>
        </div>
        <div class="driver-desc">SOTP value of the Jamnagar Giga Complex build-out (solar, battery, electrolyser). Pre-revenue at scale.</div>
        <input type="range" id="s-ne" min="84510" max="150240" step="500" value="117375">
        <div class="scale-labels"><span>Bear 84.5k cr</span><span>Bull 150.2k cr</span></div>
      </div>

      <div class="driver">
        <div class="driver-top">
          <span class="driver-name"><span class="num">05</span>WACC / discount rate</span>
          <span class="driver-val" id="v-wacc">11.0%</span>
        </div>
        <div class="driver-desc">Feeds a separate DCF cross-check (shown below), not the SOTP sum above — a purely macro / rate-cycle input.</div>
        <input type="range" id="s-wacc" min="9" max="13" step="0.1" value="11">
        <div class="scale-labels"><span>Bull (low) 9%</span><span>Bear (high) 13%</span></div>
      </div>
    </div>

    <div class="panel" id="panel">
      <div class="panel-label">Implied target price (SOTP)</div>
      <div class="price" id="outPrice">Rs 1,695</div>
      <div class="upside" id="outUpside">+27.7% vs. CMP Rs 1,327</div>
      <div class="badge" id="outBadge">OVERWEIGHT</div>

      <div class="rangebar">
        <div class="rangebar-track">
          <div class="rangebar-fill" id="barFill"></div>
          <div class="rangebar-marker" id="cmpMarker"><span class="lbl">CMP</span></div>
          <div class="rangebar-dot" id="barDot"></div>
        </div>
        <div class="rangebar-labels"><span>Rs 1,050</span><span>Rs 1,900</span></div>
      </div>

      <div class="divider"></div>
      <div class="crosscheck">
        DCF cross-check (WACC-driven): <b id="outDcf">Rs 1,580</b>
        &nbsp;&mdash;&nbsp;<span id="outDcfUpside">+19.0%</span>
      </div>

      <p class="methodology">
        Model: Target = O2C + Digital Services + Retail + New Energy (per-share SOTP contributions) &minus; net debt/share.
        Rating thresholds: upside &ge;15% Overweight, &minus;5% to 15% Neutral, below &minus;5% Underweight.
        Same methodology as Section 12 of the full report; figures may differ by a rupee or two from rounding.
      </p>
    </div>

  </div>

  <footer>
    Independent portfolio research publication, not affiliated with Reliance Industries Limited or any brokerage.
    Not investment advice. Companion tool to the full <em>Reliance Industries Limited &mdash; Equity Research Report</em>
    (Zaid Terminal Research Desk). All base-case figures as of 20 July 2026.
  </footer>

</div>

<script>
(function(){
  const CMP = 1327.2;
  const NET_DEBT_PER_SHARE = 90.8;
  const BAR_MIN = 1050, BAR_MAX = 1900;

  const els = {
    o2c: document.getElementById('s-o2c'),
    jio: document.getElementById('s-jio'),
    retail: document.getElementById('s-retail'),
    ne: document.getElementById('s-ne'),
    wacc: document.getElementById('s-wacc'),
    tail: document.getElementById('t-tail'),
  };
  const vlabels = {
    o2c: document.getElementById('v-o2c'),
    jio: document.getElementById('v-jio'),
    retail: document.getElementById('v-retail'),
    ne: document.getElementById('v-ne'),
    wacc: document.getElementById('v-wacc'),
  };
  const out = {
    price: document.getElementById('outPrice'),
    upside: document.getElementById('outUpside'),
    badge: document.getElementById('outBadge'),
    dcf: document.getElementById('outDcf'),
    dcfUpside: document.getElementById('outDcfUpside'),
    fill: document.getElementById('barFill'),
    dot: document.getElementById('barDot'),
    cmpMarker: document.getElementById('cmpMarker'),
  };

  const BADGE_STYLE = {
    OVERWEIGHT: {bg:'#e8f1ec', fg:'#1e6b3c', border:'#1e6b3c'},
    NEUTRAL:    {bg:'#f5f0e0', fg:'#8a6d1d', border:'#8a6d1d'},
    UNDERWEIGHT:{bg:'#f7eaea', fg:'#9c2b2b', border:'#9c2b2b'},
  };

  function rating(upside){
    if (upside >= 15) return 'OVERWEIGHT';
    if (upside >= -5) return 'NEUTRAL';
    return 'UNDERWEIGHT';
  }

  function lerp(x, x0, x1, y0, y1){ return y0 + (y1-y0)*(x-x0)/(x1-x0); }

  // Piecewise-linear interpolation through the exact scenario breakpoints
  // published in Section 12 of the full report (the breakpoints are not
  // evenly spaced on the input axis, so a naive two-point lerp between the
  // bear/bull endpoints would miss the tabulated base-case value — this
  // walks the actual segments so every anchor point matches exactly).
  function piecewise(x, xs, ys){
    if (x <= xs[0]) return ys[0];
    if (x >= xs[xs.length-1]) return ys[ys.length-1];
    for (let i=0;i<xs.length-1;i++){
      if (x >= xs[i] && x <= xs[i+1]) return lerp(x, xs[i], xs[i+1], ys[i], ys[i+1]);
    }
    return ys[ys.length-1];
  }

  const O2C_X = [8,10,13,16,19],       O2C_Y = [298.3,313.9,329.5,345.1,360.6];
  const RETAIL_X = [6.5,7.5,7.9,9.0,10.5], RETAIL_Y = [520.1,554.8,589.5,624.2,658.9];
  const WACC_X = [9,10,11,12,13],      WACC_Y = [1730,1650,1580,1510,1430];

  function o2cPerShare(x){ return piecewise(x, O2C_X, O2C_Y); }
  function jioPerShare(x){ return lerp(x, 100, 180, 658.9, 901.7); } // exactly linear across full range
  function retailPerShare(x){ return piecewise(x, RETAIL_X, RETAIL_Y); }
  function nePerShare(totalCr){ return totalCr/1354; } // exactly proportional
  function dcfPrice(wacc){ return piecewise(wacc, WACC_X, WACC_Y); }

  function setBarPosition(price){
    const pct = Math.max(0, Math.min(1, (price-BAR_MIN)/(BAR_MAX-BAR_MIN)));
    out.dot.style.left = (pct*100)+'%';
    out.fill.style.width = (pct*100)+'%';
  }
  function setCmpMarker(){
    const pct = Math.max(0, Math.min(1, (CMP-BAR_MIN)/(BAR_MAX-BAR_MIN)));
    out.cmpMarker.style.left = (pct*100)+'%';
  }

  function update(){
    const o2cX = parseFloat(els.o2c.value);
    const jioX = parseFloat(els.jio.value);
    const retailX = parseFloat(els.retail.value);
    const neX = parseFloat(els.ne.value);
    const waccX = parseFloat(els.wacc.value);
    const tailOn = els.tail.checked;

    els.jio.disabled = tailOn;

    vlabels.o2c.textContent = `US$ ${o2cX.toFixed(1)}/bbl`;
    vlabels.jio.textContent = tailOn ? 'Downside tail' : `US$ ${jioX.toFixed(0)} bn`;
    vlabels.retail.textContent = `${retailX.toFixed(1)}%`;
    vlabels.ne.textContent = `Rs ${Math.round(neX).toLocaleString('en-IN')} cr`;
    vlabels.wacc.textContent = `${waccX.toFixed(1)}%`;

    const o2cV = o2cPerShare(o2cX);
    const jioV = tailOn ? 461.2 : jioPerShare(jioX);
    const retailV = retailPerShare(retailX);
    const neV = nePerShare(neX);

    const target = o2cV + jioV + retailV + neV - NET_DEBT_PER_SHARE;
    const upside = (target - CMP) / CMP * 100;
    const rate = rating(upside);
    const style = BADGE_STYLE[rate];

    out.price.textContent = `Rs ${Math.round(target).toLocaleString('en-IN')}`;
    out.price.style.color = style.fg;
    out.upside.textContent = `${upside>=0?'+':''}${upside.toFixed(1)}% vs. CMP Rs ${Math.round(CMP).toLocaleString('en-IN')}`;
    out.badge.textContent = rate;
    out.badge.style.background = style.bg;
    out.badge.style.color = style.fg;
    out.badge.style.border = `1px solid ${style.border}`;

    setBarPosition(target);
    setCmpMarker();

    const dcf = dcfPrice(waccX);
    const dcfUp = (dcf - CMP) / CMP * 100;
    out.dcf.textContent = `Rs ${Math.round(dcf).toLocaleString('en-IN')}`;
    out.dcfUpside.textContent = `${dcfUp>=0?'+':''}${dcfUp.toFixed(1)}% (${rating(dcfUp)})`;
  }

  Object.values(els).forEach(el => el.addEventListener('input', update));

  document.getElementById('resetBtn').addEventListener('click', function(){
    els.o2c.value = 13; els.jio.value = 140; els.retail.value = 7.9;
    els.ne.value = 117375; els.wacc.value = 11; els.tail.checked = false;
    update();
  });

  update();
})();
</script>
</body>
</html>
